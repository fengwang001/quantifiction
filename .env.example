# ============================================================================
# T005 密钥约定：真实密钥写入 .env（已被 .gitignore 忽略），绝不入库。
# config/*.yaml 不含任何明文密钥；程序一律从环境变量读取。（宪法 IV）
# ============================================================================

# === 欧易 OKX（当前主用）。鉴权三要素：Key + Secret + Passphrase ===
# 主交易凭据（strategy/gateway）
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# Watchdog 独立凭据（独立进程 + IP 白名单 + 代码层只平仓 + 禁提现，宪法 IV）
OKX_WATCHDOG_API_KEY=
OKX_WATCHDOG_SECRET=
OKX_WATCHDOG_PASSPHRASE=

# REST 基址：默认 https://www.okx.com；若被网络限制不可达，用备用域名 https://www.okx.cab
OKX_BASE_URL=https://www.okx.com
# 1=模拟盘(demo trading)，0=实盘。首次务必 =1（阶段 A）
OKX_SIMULATED=1

# === 币安（保留供以后扩展，当前不用）===
# BINANCE_KEY=
# BINANCE_SECRET=
# BINANCE_WATCHDOG_KEY=
# BINANCE_WATCHDOG_SECRET=
# BINANCE_TESTNET=1

# --- 存储 ---
PG_DSN=postgresql://quant:quant_dev@localhost:5432/quantifiction
REDIS_URL=redis://localhost:6379/0

# --- 冷层 OSS ---
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# --- 认知层（grsai OpenAI 兼容端点）---
GRSAI_API_KEY=            # sk-xxx，前往 https://grsai.ai/zh/dashboard/api-keys 获取
GRSAI_BASE_URL=https://grsaiapi.com   # 全球节点；国内可改 https://grsai.dakka.com.cn

# --- 飞书告警 ---
FEISHU_WEBHOOK=
FEISHU_WEBHOOK_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
