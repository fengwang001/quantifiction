# 密钥绝不入库（宪法 IV / T005）
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# Python
__pycache__/
*.pyc
.venv/
venv/
dist/
build/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# 数据（自录 tick / 本地落盘，勿入库）
# data 下大文件(persist/ticks/state)不入库；例外：评估报告入库(循环记忆/历史)
data/*
!data/loop_reports/
*.parquet

# 工具
.DS_Store
Thumbs.db
.vscode/
.idea/
uv.lock
vendor/
.claude/scheduled_tasks.lock
.claude/settings.local.json
